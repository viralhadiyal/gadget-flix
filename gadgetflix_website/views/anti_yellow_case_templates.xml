<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         Anti-Yellow Case Landing Page
         Layout: Image left | Searchable Brand+Model configurator right
         Route: /anti-yellow-case
    ============================================================ -->
    <template id="anti_yellow_case_page" name="Anti-Yellow Case Landing Page">
        <t t-call="gadgetflix_website.gadgetflix_page_layout">
            <t t-set="additional_title">Anti-Yellow Clear Cases – GadgetFlix</t>

            <div id="gf-ayc-page" class="gf-ayc-page">

                <!-- ── Main PDP row (image left + configurator right) ── -->
                <section class="gf-ayc-pdp">
                    <div class="gf-container gf-ayc-pdp__inner"
                         id="gf-ayc-configurator"
                         t-if="brands"
                         t-att-data-default-product-id="default_brand['product_id'] if default_brand else 0"
                         t-att-data-default-brand-id="default_brand['brand_value_id'] if default_brand else 0">

                        <!-- ── LEFT: Product image ──────────────────── -->
                        <div class="gf-ayc-pdp__image-col">
                            <div class="gf-ayc-pdp__image-wrap" id="o-carousel-product">
                                <t t-call="website_sale.shop_product_images"/>
                            </div>
                        </div>

                        <!-- ── RIGHT: Configurator ──────────────────── -->
                        <div class="gf-ayc-pdp__config-col">

                            <!-- Product title + badges -->
                            <div class="gf-ayc-pdp__title-row">
                                <div class="gf-ayc-badges mb-2 d-flex align-items-center gap-2">
                                    <span class="gf-ayc-badge gf-badge-warranty">
                                        Lifetime Warranty
                                    </span>
                                    <span class="gf-ayc-badge gf-badge-gifts">
                                        3 Free Gifts
                                    </span>
                                </div>
                                <h1 class="gf-ayc-pdp__title">Anti-Yellow Magsafe Clear Case<span id="gf-ayc-title-model"></span></h1>
                                
                                <!-- Ratings -->
                                <div class="gf-ayc-ratings d-flex align-items-center gap-2 mt-2 mb-2">
                                    <div class="stars" style="color: #fbbc04; font-size: 1rem;">
                                        <i class="fa fa-star"/>
                                        <i class="fa fa-star"/>
                                        <i class="fa fa-star"/>
                                        <i class="fa fa-star"/>
                                        <i class="fa fa-star-half-o"/>
                                    </div>
                                    <span class="text-muted" style="font-size: 0.85rem; font-weight: 500;">4.8 (1,284 Reviews)</span>
                                </div>
                            </div>

                            <!-- Price -->
                            <div class="gf-ayc-pdp__price-row mb-3">
                                <span class="gf-ayc-pdp__price" id="gf-ayc-price">
                                    <t t-if="default_brand">
                                        <t t-out="default_brand['first_price']"
                                           t-options="{'widget': 'monetary', 'display_currency': website.currency_id}"/>
                                    </t>
                                    <t t-else="">—</t>
                                </span>
                            </div>

                            <!-- Bundle & Save -->
                            <div class="gf-ayc-bundle-compact mb-3">
                                <h6 class="gf-ayc-sec-title">🔥 Bundle &amp; save more</h6>
                                <div class="d-flex gap-2">
                                    <div class="gf-ayc-bundle-card flex-fill">
                                        <div class="b-qty">1 case</div>
                                        <div class="b-price">₹549</div>
                                    </div>
                                    <div class="gf-ayc-bundle-card popular flex-fill">
                                        <div class="b-badge">MOST POPULAR</div>
                                        <div class="b-qty">2 cases</div>
                                        <div class="b-price">₹749</div>
                                        <div class="b-save">Save ₹349</div>
                                    </div>
                                    <div class="gf-ayc-bundle-card flex-fill">
                                        <div class="b-qty">3 cases</div>
                                        <div class="b-price">₹849</div>
                                        <div class="b-save">Save ₹798</div>
                                    </div>
                                </div>
                            </div>

                            <!-- Free Gifts Compact Banner -->
                            <div class="gf-ayc-gifts-compact mb-4">
                                <div class="g-header">🎁 3 Free Gifts With Every Order</div>
                                <div class="g-items">
                                    <div class="g-item">
                                        <span>Cable Protector</span>
                                        <div class="g-image-box">
                                            <img src="/gadgetflix_website/static/src/img/gift_cable_protector.webp" alt="Cable Protector"/>
                                        </div>
                                    </div>
                                    <div class="g-item">
                                        <span>C-to-C Cable</span>
                                        <div class="g-image-box">
                                            <img src="/gadgetflix_website/static/src/img/gift_c_to_c_cable.webp" alt="C-to-C Cable"/>
                                        </div>
                                    </div>
                                    <div class="g-item">
                                        <span>Pop-up Stand</span>
                                        <div class="g-image-box">
                                            <img src="/gadgetflix_website/static/src/img/gift_popup_stand.webp" alt="Pop-up Stand"/>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Divider -->
                            <hr class="gf-ayc-pdp__divider"/>

                            <!-- Step 1: Brand (radio squarebox) -->
                            <div class="gf-ayc-field gf-ayc-field--brand" id="gf-ayc-brand-dropdown">
                                <div class="gf-ayc-field__header">
                                    <label class="gf-ayc-field__label">Select Brand</label>
                                    <span id="gf-ayc-brand-label" class="gf-ayc-field__selected-value">Choose a brand…</span>
                                </div>
                                <div class="gf-ayc-brand-grid-wrapper">
                                    <!-- Dummy elements to satisfy JS makeDropdown helper without errors -->
                                    <div id="gf-ayc-brand-trigger" style="display: none;"/>
                                    <div id="gf-ayc-brand-panel" style="display: none;">
                                        <input type="text" id="gf-ayc-brand-search" style="display: none;"/>
                                    </div>

                                    <div class="gf-ayc-brand-grid" id="gf-ayc-brand-listbox" role="radiogroup">
                                        <t t-foreach="brands" t-as="brand">
                                            <div class="gf-ayc-dropdown__item"
                                                 role="option"
                                                 t-att-data-brand-value-id="brand['brand_value_id']"
                                                 t-att-data-product-id="brand['product_id']"
                                                 t-att-data-first-price="brand['first_price']"
                                                 t-att-data-image-url="brand['first_image_url']"
                                                 t-att-data-brand-name="brand['brand_name']"
                                                 t-att-aria-selected="'true' if brand_index == 0 else 'false'">
                                                <span class="gf-ayc-dropdown__item-name" t-out="brand['brand_name']"/>
                                            </div>
                                        </t>
                                    </div>
                                </div>
                            </div>

                            <!-- Step 2: Model (searchable dropdown) -->
                            <div class="gf-ayc-field gf-ayc-field--model">
                                <label class="gf-ayc-field__label" for="gf-ayc-model-search">
                                    Select Model
                                </label>
                                <div class="gf-ayc-dropdown gf-ayc-dropdown--disabled" id="gf-ayc-model-dropdown">
                                    <div class="gf-ayc-dropdown__trigger" id="gf-ayc-model-trigger"
                                         role="combobox" aria-haspopup="listbox"
                                         aria-expanded="false" aria-controls="gf-ayc-model-listbox"
                                         tabindex="0">
                                        <span id="gf-ayc-model-label">Select a brand first…</span>
                                        <span class="gf-ayc-spinner gf-ayc-dropdown__spinner" id="gf-ayc-model-spinner" hidden="hidden" aria-label="Loading"/>
                                        <i class="fa fa-angle-down gf-ayc-dropdown__caret" aria-hidden="true"/>
                                    </div>
                                    <div class="gf-ayc-dropdown__panel" id="gf-ayc-model-panel" role="listbox" aria-label="Model options">
                                        <div class="gf-ayc-dropdown__search-wrap">
                                            <i class="fa fa-search" aria-hidden="true"/>
                                            <input
                                                type="text"
                                                id="gf-ayc-model-search"
                                                class="gf-ayc-dropdown__search"
                                                placeholder="Search model…"
                                                autocomplete="off"
                                                aria-label="Search model"
                                            />
                                        </div>
                                        <ul class="gf-ayc-dropdown__list" id="gf-ayc-model-listbox">
                                            <!-- Populated by JS -->
                                        </ul>
                                        <p class="gf-ayc-dropdown__no-results" hidden="hidden">No results found</p>
                                    </div>
                                </div>
                            </div>

                            <!-- Divider -->
                            <hr class="gf-ayc-pdp__divider"/>

                            <!-- Qty + Add to Cart + Buy Now -->
                            <div class="gf-ayc-buy" id="gf-ayc-buy">
                                <div id="add_to_cart_wrap" class="d-flex flex-nowrap align-items-center gap-2">
                                    <div class="css_quantity input-group d-inline-flex align-middle border bg-white">
                                        <button type="button" class="btn btn-link pe-2 border-0 text-dark gf-ayc-qty-btn" id="gf-ayc-qty-dec" aria-label="Remove one" title="Remove one">
                                            <i class="fa fa-minus"></i>
                                        </button>
                                        <input type="text" id="gf-ayc-qty" class="form-control quantity text-center border-0 bg-transparent fw-bold" value="1" min="1" max="99"/>
                                        <button type="button" class="btn btn-link ps-2 border-0 text-dark gf-ayc-qty-btn" id="gf-ayc-qty-inc" aria-label="Add one" title="Add one">
                                            <i class="fa fa-plus"></i>
                                        </button>
                                    </div>
                                    <button type="button" id="gf-ayc-add-to-cart" class="gf-ayc-buy__cart-btn flex-grow-1" disabled="disabled">
                                        <i class="fa fa-shopping-cart me-2" aria-hidden="true"/>
                                        <span>Add to Cart</span>
                                    </button>
                                </div>
                            </div>

                            <!-- Trust badges -->
                            <div class="gf-ayc-pdp__trust">
                                <div class="gf-ayc-trust-item">
                                    <i class="fa fa-truck" aria-hidden="true"/>
                                    <div>
                                        <strong>Fast Delivery</strong>
                                        <span>3–7 days</span>
                                    </div>
                                </div>
                                <div class="gf-ayc-trust-item">
                                    <i class="fa fa-shield" aria-hidden="true"/>
                                    <div>
                                        <strong>Lifetime Warranty</strong>
                                        <span>Anti-yellow</span>
                                    </div>
                                </div>
                                <div class="gf-ayc-trust-item">
                                    <i class="fa fa-lock" aria-hidden="true"/>
                                    <div>
                                        <strong>Secure Payment</strong>
                                        <span>100% Safe</span>
                                    </div>
                                </div>
                            </div>

                        </div><!-- /.gf-ayc-pdp__config-col -->
                    </div>

                    <!-- Empty state -->
                    <div t-else="" class="gf-container gf-ayc-empty">
                        <i class="fa fa-exclamation-circle" aria-hidden="true"/>
                        <p>No anti-yellow products are currently available. Check back soon!</p>
                        <a href="/shop" class="gf-ayc-btn-link">Browse all products</a>
                    </div>
                </section>

                <!-- ── Lifestyle / Product Showcase ─────────────────────────── -->
                <section class="gf-ayc-showcase">
                    <div class="gf-container">
                        <div class="gf-ayc-showcase__header text-center">
                            <h2>Designed to Showcase. Built to Protect.</h2>
                            <p>Premium materials meet military-grade drop defense. Our crystal-clear cases protect your phone without masking its color or styling.</p>
                        </div>
                        <div class="gf-ayc-marquee">
                            <div class="gf-ayc-marquee-track">
                                <!-- Original Set -->
                                <t t-foreach="[1, 2, 3, 4, 5]" t-as="i">
                                    <div class="gf-ayc-marquee-item">
                                        <img t-attf-src="/gadgetflix_website/static/src/img/anti_yellow_no_border_#{i}.webp" width="2000" height="2000" t-attf-alt="Clear Case #{i}" loading="lazy"/>
                                    </div>
                                </t>
                                <!-- Duplicated Set for infinite loop -->
                                <t t-foreach="[1, 2, 3, 4, 5]" t-as="i">
                                    <div class="gf-ayc-marquee-item">
                                        <img t-attf-src="/gadgetflix_website/static/src/img/anti_yellow_no_border_#{i}.webp" width="2000" height="2000" t-attf-alt="Clear Case #{i}" loading="lazy"/>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- ── Unique Interactive Video Accordion ── -->
                <section class="gf-ayc-accordion-section">
                    <div class="gf-container-fluid px-0">
                        <div class="gf-ayc-accordion-header text-center">
                            <h2>Engineered for Perfection</h2>
                            <p>Hover over the cards to explore what makes our clear case the best in class.</p>
                        </div>
                        
                        <div class="gf-ayc-accordion-wrapper">
                            
                            <!-- Accordion Item 1 -->
                            <div class="gf-ayc-accordion-item">
                                <video autoplay="autoplay" loop="loop" muted="muted" playsinline="playsinline">
                                    <source src="/gadgetflix_website/static/src/video/anti_yellow_case.mp4" type="video/mp4"/>
                                </video>
                                <div class="gf-ayc-accordion-overlay"></div>
                                <div class="gf-ayc-accordion-content">
                                    <div class="gf-ayc-acc-icon">01</div>
                                    <div class="gf-ayc-acc-text">
                                        <h3>UV-Resistant Premium Bayer Material</h3>
                                        <p>Crafted from premium Bayer TPU infused with advanced UV-defending molecules. Active blue-light absorption keeps the case crystal clear and prevents yellowing caused by sunlight or sweat.</p>
                                    </div>
                                </div>
                            </div>

                            <!-- Accordion Item 2 -->
                             <div class="gf-ayc-accordion-item">
                                 <video autoplay="autoplay" loop="loop" muted="muted" playsinline="playsinline">
                                     <source src="/gadgetflix_website/static/src/video/yellow_free_guarantee.mp4" type="video/mp4"/>
                                 </video>
                                 <div class="gf-ayc-accordion-overlay"></div>
                                 <div class="gf-ayc-accordion-content">
                                     <div class="gf-ayc-acc-icon">02</div>
                                     <div class="gf-ayc-acc-text">
                                         <h3>Advanced Drop &amp; Corner Protection</h3>
                                         <p>Equipped with custom protective air cushions in all four corners and raised bumpers. Keeps your screen and camera lenses completely safe from accidental drops.</p>
                                     </div>
                                 </div>
                             </div>

                             <!-- Accordion Item 3 -->
                             <div class="gf-ayc-accordion-item">
                                 <video autoplay="autoplay" loop="loop" muted="muted" playsinline="playsinline">
                                     <source src="/gadgetflix_website/static/src/video/magsafe_ready.mp4" type="video/mp4"/>
                                 </video>
                                 <div class="gf-ayc-accordion-overlay"></div>
                                 <div class="gf-ayc-accordion-content">
                                     <div class="gf-ayc-acc-icon">03</div>
                                     <div class="gf-ayc-acc-text">
                                         <h3>Integrated MagSafe-Compatible Ring</h3>
                                         <p>Features a built-in circle of magnets to ensure a secure snap-on connection with MagSafe accessories, mounts, and wireless chargers.</p>
                                     </div>
                                 </div>
                             </div>

                             <!-- Accordion Item 4 -->
                             <div class="gf-ayc-accordion-item">
                                 <video autoplay="autoplay" loop="loop" muted="muted" playsinline="playsinline">
                                     <source src="/gadgetflix_website/static/src/video/stylish_premium.mp4" type="video/mp4"/>
                                 </video>
                                 <div class="gf-ayc-accordion-overlay"></div>
                                 <div class="gf-ayc-accordion-content">
                                     <div class="gf-ayc-acc-icon">04</div>
                                     <div class="gf-ayc-acc-text">
                                         <h3>Slim Profile &amp; Ergonomic Grip</h3>
                                         <p>Slim design showcases your phone's original aesthetics. The micro-dot laser texture prevents wet-look watermarks and offers an anti-slip, comfortable grip.</p>
                                     </div>
                                 </div>
                             </div>

                             <!-- Accordion Item 5 -->
                             <div class="gf-ayc-accordion-item">
                                 <video autoplay="autoplay" loop="loop" muted="muted" playsinline="playsinline">
                                     <source src="/gadgetflix_website/static/src/video/stay_protected.mp4" type="video/mp4"/>
                                 </video>
                                 <div class="gf-ayc-accordion-overlay"></div>
                                 <div class="gf-ayc-accordion-content">
                                     <div class="gf-ayc-acc-icon">05</div>
                                     <div class="gf-ayc-acc-text">
                                         <h3>Premium Scratch Resistance</h3>
                                         <p>Coated with a specialized self-healing optical layer that resists keys, coins, and everyday abrasions, keeping your case looking brand new day after day.</p>
                                     </div>
                                 </div>
                             </div>

                        </div>
                    </div>
                 </section>

                 <!-- ── Section A: Multi-Layer Fusion (Exploded Material View) ── -->
                 <section class="gf-ayc-engineering">
                     <div class="gf-container">
                         <div class="row align-items-center">
                             <div class="col-lg-6 mb-5 mb-lg-0">
                                 <span class="gf-badge mb-3">MATERIAL SCIENCE</span>
                                 <h2 class="gf-ayc-eng-heading">Three Layers of Invisible Protection</h2>
                                 <p class="gf-ayc-eng-desc">Standard clear cases are made from single-layer cheap TPU that easily absorbs oils and yellows. We fused three specialized material layers to create the ultimate clear case.</p>
                                 
                                 <div class="gf-ayc-layers-list">
                                     <div class="gf-ayc-layer-item">
                                         <div class="layer-indicator">01</div>
                                         <div>
                                             <strong>Scratch-Resistant Armor</strong>
                                             <p>An optical outer coating engineered to resist scratches from keys, coins, and daily contact, keeping your case clear and pristine.</p>
                                         </div>
                                     </div>
                                     <div class="gf-ayc-layer-item">
                                         <div class="layer-indicator">02</div>
                                         <div>
                                             <strong>High-Impact Core</strong>
                                             <p>A rigid, crystal-clear backing that distributes pressure and provides solid structural strength to prevent bending or cracking.</p>
                                         </div>
                                     </div>
                                     <div class="gf-ayc-layer-item">
                                         <div class="layer-indicator">03</div>
                                         <div>
                                             <strong>UV-Defending Polymer Blend</strong>
                                             <p>Infused throughout the TPU frame, this layer actively blocks UV light and sweat to prevent chemical yellowing at the molecular level.</p>
                                         </div>
                                     </div>
                                 </div>
                             </div>
                             <div class="col-lg-6">
                                 <div class="gf-ayc-exploded-visual">
                                     <!-- Exploded CSS layers representation -->
                                     <div class="exploded-layer layer-3">
                                         <span class="layer-tag">01 / Scratch-Resistant Armor</span>
                                     </div>
                                     <div class="exploded-layer layer-2">
                                         <span class="layer-tag">02 / High-Impact Core</span>
                                     </div>
                                     <div class="exploded-layer layer-1">
                                         <span class="layer-tag">03 / UV-Defending Polymer</span>
                                     </div>
                                 </div>
                             </div>
                         </div>
                     </div>
                 </section>

                 <!-- ── Section B: Clarity Comparison Timeline ── -->
                 <section class="gf-ayc-comparison">
                     <div class="gf-container">
                         <div class="gf-ayc-comp-header text-center mb-5">
                             <span class="gf-badge mb-3">COMPARE THE DIFFERENCE</span>
                             <h2>Clarity That Stands the Test of Time</h2>
                             <p>Most clear cases look good on Day 1. Here is how Gadgetflix compares to standard clear cases over a 6-month timeline.</p>
                         </div>
                         
                         <div class="gf-ayc-comp-grid">
                             <!-- Header Row -->
                             <div class="comp-row comp-header">
                                 <div class="comp-col">Timeline</div>
                                 <div class="comp-col">Standard Clear Case</div>
                                 <div class="comp-col highlight">Gadgetflix Anti-Yellow Case</div>
                             </div>
                             
                             <!-- Row 1 -->
                             <div class="comp-row">
                                 <div class="comp-col comp-day font-weight-bold">Day 1</div>
                                 <div class="comp-col text-muted" data-label="Standard Clear Case">Crystal clear, looks great.</div>
                                 <div class="comp-col highlight text-success font-weight-bold" data-label="Gadgetflix Anti-Yellow Case">✓ Crystal clear, high-gloss shine.</div>
                             </div>
                             
                             <!-- Row 2 -->
                             <div class="comp-row">
                                 <div class="comp-col comp-day font-weight-bold">Day 90</div>
                                 <div class="comp-col text-muted" data-label="Standard Clear Case">Slight greasy yellow tint around edges.</div>
                                 <div class="comp-col highlight text-success font-weight-bold" data-label="Gadgetflix Anti-Yellow Case">✓ 100% Clear, zero color change.</div>
                             </div>
                             
                             <!-- Row 3 -->
                             <div class="comp-row">
                                 <div class="comp-col comp-day font-weight-bold">Day 180</div>
                                 <div class="comp-col text-muted text-warning" data-label="Standard Clear Case">Dirty yellow-brown color. Sticky feel.</div>
                                 <div class="comp-col highlight text-success font-weight-bold" data-label="Gadgetflix Anti-Yellow Case">✓ Pristine transparency, looks like new.</div>
                             </div>
                         </div>
                     </div>
                 </section>

                 <!-- ── Official Warranty Section ─────────────────────────── -->
                 <t t-call="gadgetflix_website.gadgetflix_warranty"/>


                <!-- ── FAQ Section ─────────────────────────────────────────── -->
                <section class="gf-ayc-faq-section">
                    <div class="gf-container">
                        <div class="gf-ayc-faq-header text-center">
                            <span class="gf-badge mb-3">Got Questions?</span>
                            <h2>Frequently Asked Questions</h2>
                        </div>
                        <div class="row gf-ayc-faq-row" id="ayc-faq-accordion">
                            <!-- Left Column -->
                            <div class="col-md-6 mb-4 mb-md-0">
                                <div class="accordion gf-ayc-accordion">
                                    <!-- FAQ 1 -->
                                    <div class="accordion-item">
                                        <h2 class="accordion-header" id="faq-heading-1">
                                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq-collapse-1" aria-expanded="false" aria-controls="faq-collapse-1">
                                                What makes this case different from others?
                                            </button>
                                        </h2>
                                        <div id="faq-collapse-1" class="accordion-collapse collapse" aria-labelledby="faq-heading-1" data-bs-parent="#ayc-faq-accordion">
                                            <div class="accordion-body">
                                                Our case is built with advanced UV Shield Technology, designed to prevent yellowing over time. This ensures your phone case stays crystal clear and maintains its fresh look for much longer compared to standard clear cases.
                                            </div>
                                        </div>
                                    </div>

                                    <!-- FAQ 2 -->
                                    <div class="accordion-item">
                                        <h2 class="accordion-header" id="faq-heading-2">
                                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq-collapse-2" aria-expanded="false" aria-controls="faq-collapse-2">
                                                What is the anti-yellowing guarantee?
                                            </button>
                                        </h2>
                                        <div id="faq-collapse-2" class="accordion-collapse collapse" aria-labelledby="faq-heading-2" data-bs-parent="#ayc-faq-accordion">
                                            <div class="accordion-body">
                                                We provide a lifetime anti-yellowing guarantee. If your case ever develops yellowing, you are eligible for a one-time free replacement—no hassle.
                                            </div>
                                        </div>
                                    </div>

                                    <!-- FAQ 4 -->
                                    <div class="accordion-item">
                                        <h2 class="accordion-header" id="faq-heading-4">
                                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq-collapse-4" aria-expanded="false" aria-controls="faq-collapse-4">
                                                Does the case protect against drops and scratches?
                                            </button>
                                        </h2>
                                        <div id="faq-collapse-4" class="accordion-collapse collapse" aria-labelledby="faq-heading-4" data-bs-parent="#ayc-faq-accordion">
                                            <div class="accordion-body">
                                                Yes, the case is designed to provide daily protection against minor drops, bumps, and scratches, all while maintaining a slim and lightweight profile.
                                            </div>
                                        </div>
                                    </div>

                                    <!-- FAQ 5 -->
                                    <div class="accordion-item">
