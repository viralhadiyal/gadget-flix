<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="gadgetflix_portal_address_hide_b2b_fields" inherit_id="portal.address_form_fields" priority="80">
        <xpath expr="//t[@name='b2b_fields']" position="attributes">
            <attribute name="t-if">False</attribute>
        </xpath>
    </template>

    <template id="gadgetflix_checkout_address_hide_b2b_fields" inherit_id="website_sale.address_form_fields" priority="80">
        <xpath expr="//t[@name='b2b_fields']" position="attributes">
            <attribute name="t-if">False</attribute>
        </xpath>
    </template>

    <template id="gadgetflix_portal_hide_same_as_delivery" inherit_id="portal.my_addresses" priority="999">
        <xpath expr="//input[@id='use_delivery_as_billing']/ancestor::div[contains(concat(' ', normalize-space(@class), ' '), ' form-check ')][1]" position="attributes">
            <attribute name="t-if">False</attribute>
        </xpath>
    </template>

    <template id="gadgetflix_checkout_hide_same_as_delivery" inherit_id="website_sale.billing_address_list" priority="999">
        <xpath expr="//input[@id='use_delivery_as_billing']/ancestor::div[contains(concat(' ', normalize-space(@class), ' '), ' form-check ')][1]" position="attributes">
            <attribute name="t-if">False</attribute>
        </xpath>
    </template>

    <template id="gadgetflix_checkout_hide_shared_address_warning" inherit_id="website_sale.address" priority="80">
        <xpath expr="//div[@role='alert' and contains(@t-if, 'use_delivery_as_billing')]" position="attributes">
            <attribute name="class" add="d-none" separator=" "/>
        </xpath>
    </template>

    <template id="gadgetflix_hide_same_as_delivery_inline_css" inherit_id="website.layout">
        <xpath expr="//head" position="inside">
            <style>
                #billing_address_list .form-check:has(#use_delivery_as_billing),
                .o_portal_addresses .form-check:has(#use_delivery_as_billing),
                #use_delivery_as_billing_label,
                label[for="use_delivery_as_billing"],
                #use_delivery_as_billing,
                #use_delivery_as_billing + span {
                    display: none !important;
                }
            </style>
        </xpath>
    </template>

</odoo>
