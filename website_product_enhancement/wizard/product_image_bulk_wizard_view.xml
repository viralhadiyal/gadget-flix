<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_product_image_bulk_wizard_form" model="ir.ui.view">
        <field name="name">product.image.bulk.wizard.form</field>
        <field name="model">product.image.bulk.wizard</field>
        <field name="arch" type="xml">

            <form string="Bulk Image &amp; Weight Upload">
                <sheet>

                    <div class="oe_title">
                        <label for="product_tmpl_id"/>
                        <h1>
                            <field name="product_tmpl_id"
                                   readonly="1"
                                   options="{'no_open': True}"/>
                        </h1>
                    </div>

                    <separator string="① Product Template Images"/>
                    <group>
                        <field name="template_image_action" widget="radio" options="{'horizontal': true}"/>
                    </group>
                    <div class="alert alert-info" role="alert">
                        <i class="fa fa-info-circle"/>
                        <strong>Replace Existing Images</strong> clears current extra images before uploading. 
                        <strong>Add/Keep Images</strong> appends to existing extra images.
                    </div>
                    <label for="template_attachment_ids" string="Upload Images (Multi-select)"/>
                    <field name="template_attachment_ids" widget="many2many_binary"/>
                    <field name="template_image_line_ids">
                        <list editable="bottom">
                            <field name="image" widget="image" options="{'size': [64, 64]}"/>
                            <field name="image_filename"/>
                            <field name="is_main_image" widget="boolean_toggle"/>
                        </list>
                    </field>

                    <separator string="② Bulk Weight"/>
                    <group>
                        <field name="bulk_weight"
                               placeholder="0.00 — overrides all variant weights when set"/>
                    </group>

                    <separator string="③ Variant Images &amp; Per-Variant Weight"/>
                    <div class="alert alert-warning mb-2" role="alert">
                        <i class="fa fa-mouse-pointer"/>
                        <strong>Click on any variant row</strong>
                        below to open its image
                        upload dialog. Select multiple images at once using Ctrl/Cmd+Click
                        in the file picker.
                    </div>
                    <field name="variant_line_ids">
                        <list string="Variants">
                            <field name="product_id" column_invisible="1"/>
                            <field name="variant_name" string="Variant" readonly="1"/>
                            <field name="weight"/>
                            <field name="image_count"
                                   string="Images Queued"
                                   readonly="1"/>
                        </list>

                        <form string="Upload Variant Images">
                            <sheet>
                                <div class="oe_title">
                                    <h2>
                                        <field name="variant_name" readonly="1"/>
                                    </h2>
                                </div>
                                <group>
                                    <field name="weight"/>
                                    <field name="image_action" widget="radio" options="{'horizontal': true}"/>
                                </group>
                                <div class="alert alert-info" role="alert">
                                    <i class="fa fa-info-circle"/>
                                    Click <strong>Upload</strong> and select multiple image
                                    files at once (hold Ctrl/Cmd to multi-select in file picker).
                                </div>
                                <label for="image_attachment_ids" string="Upload Images (Multi-select)"/>
                                <field name="image_attachment_ids" widget="many2many_binary"/>
                                <field name="variant_image_ids">
                                    <list editable="bottom">
                                        <field name="image" widget="image" options="{'size': [64, 64]}"/>
                                        <field name="image_filename"/>
                                        <field name="is_main_image" widget="boolean_toggle"/>
                                    </list>
                                </field>
                                <field name="product_id" invisible="1"/>
                            </sheet>
                        </form>
                    </field>

                </sheet>

                <footer>
                    <button string="Apply"
                            name="action_apply"
                            type="object"
                            class="btn-primary"/>
                    <button string="Discard"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>

        </field>
    </record>
    <record id="action_product_image_bulk_wizard" model="ir.actions.act_window">
        <field name="name">Bulk Images &amp; Weights</field>
        <field name="res_model">product.image.bulk.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
