<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ga4_report_list" model="ir.ui.view">
        <field name="name">ga4.report.list</field>
        <field name="model">ga4.report</field>
        <field name="arch" type="xml">
            <list string="GA4 Reports">
                <field name="report_date"/>
                <field name="connection_id"/>
                <field name="report_type"/>
                <field name="dimension_key"/>
                <field name="source" optional="show"/>
                <field name="medium" optional="show"/>
                <field name="campaign" optional="show"/>
                <field name="page_path" optional="hide"/>
                <field name="page_location" optional="hide"/>
                <field name="page_title" optional="hide"/>
                <field name="event_name" optional="show"/>
                <field name="country" optional="hide"/>
                <field name="city" optional="hide"/>
                <field name="device_category" optional="hide"/>
                <field name="operating_system" optional="hide"/>
                <field name="browser" optional="hide"/>
                <field name="platform" optional="hide"/>
                <field name="stream_id" optional="hide"/>
                <field name="total_users" sum="Total Users"/>
                <field name="new_users" sum="New Users"/>
                <field name="sessions" sum="Sessions"/>
                <field name="screen_page_views" sum="Views"/>
                <field name="event_count" sum="Events"/>
                <field name="conversions" sum="Key Events"/>
                <field name="event_value" sum="Event Value"/>
                <field name="event_count_per_user" avg="Events/User"/>
                <field name="purchase_revenue" sum="Revenue"/>
            </list>
        </field>
    </record>

    <record id="view_ga4_report_form" model="ir.ui.view">
        <field name="name">ga4.report.form</field>
        <field name="model">ga4.report</field>
        <field name="arch" type="xml">
            <form string="GA4 Report">
                <sheet>
                    <group>
                        <group>
                            <field name="connection_id"/>
                            <field name="report_type"/>
                            <field name="report_date"/>
                            <field name="dimension_key"/>
                            <field name="source"/>
                            <field name="medium"/>
                            <field name="campaign"/>
                            <field name="page_path"/>
                            <field name="page_location"/>
                            <field name="page_title"/>
                        </group>
                        <group>
                            <field name="event_name"/>
                            <field name="country"/>
                            <field name="city"/>
                            <field name="device_category"/>
                            <field name="operating_system"/>
                            <field name="browser"/>
                            <field name="platform"/>
                            <field name="stream_id"/>
                            <field name="total_users"/>
                            <field name="sessions"/>
                            <field name="screen_page_views"/>
                            <field name="event_count"/>
                            <field name="conversions"/>
                            <field name="event_value"/>
                            <field name="event_count_per_user"/>
                            <field name="purchase_revenue"/>
                        </group>
                    </group>
                    <group>
                        <field name="dimensions_json"/>
                        <field name="metrics_json"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_ga4_report_search" model="ir.ui.view">
        <field name="name">ga4.report.search</field>
        <field name="model">ga4.report</field>
        <field name="arch" type="xml">
            <search string="GA4 Reports">
                <field name="connection_id"/>
                <field name="report_type"/>
                <field name="report_date"/>
                <field name="dimension_key"/>
                <field name="source"/>
                <field name="medium"/>
                <field name="campaign"/>
                <field name="page_path"/>
                <field name="page_location"/>
                <field name="page_title"/>
                <field name="event_name"/>
                <field name="country"/>
                <field name="city"/>
                <field name="device_category"/>
                <field name="operating_system"/>
                <field name="browser"/>
                <field name="platform"/>
                <field name="stream_id"/>
                <filter name="group_report_type" string="Report Type" context="{'group_by': 'report_type'}"/>
                <filter name="group_report_date" string="Date" context="{'group_by': 'report_date'}"/>
                <filter name="group_dimension_key" string="Dimension" context="{'group_by': 'dimension_key'}"/>
                <filter name="group_source" string="Source" context="{'group_by': 'source'}"/>
                <filter name="group_campaign" string="Campaign" context="{'group_by': 'campaign'}"/>
                <filter name="group_event" string="Event" context="{'group_by': 'event_name'}"/>
                <filter name="group_page" string="Page" context="{'group_by': 'page_path'}"/>
                <filter name="group_country" string="Country" context="{'group_by': 'country'}"/>
                <filter name="group_device" string="Device" context="{'group_by': 'device_category'}"/>
                <filter name="group_platform" string="Platform" context="{'group_by': 'platform'}"/>
            </search>
        </field>
    </record>

    <record id="view_ga4_report_graph" model="ir.ui.view">
        <field name="name">ga4.report.graph</field>
        <field name="model">ga4.report</field>
        <field name="arch" type="xml">
            <graph string="GA4 Reports" type="line">
                <field name="report_date" interval="day"/>
                <field name="total_users" type="measure"/>
                <field name="sessions" type="measure"/>
                <field name="screen_page_views" type="measure"/>
                <field name="event_count" type="measure"/>
                <field name="conversions" type="measure"/>
                <field name="event_value" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_ga4_report_pivot" model="ir.ui.view">
        <field name="name">ga4.report.pivot</field>
        <field name="model">ga4.report</field>
        <field name="arch" type="xml">
            <pivot string="GA4 Reports">
                <field name="report_type" type="row"/>
                <field name="report_date" interval="month" type="col"/>
                <field name="total_users" type="measure"/>
                <field name="sessions" type="measure"/>
                <field name="screen_page_views" type="measure"/>
                <field name="event_count" type="measure"/>
                <field name="conversions" type="measure"/>
                <field name="event_value" type="measure"/>
                <field name="purchase_revenue" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_ga4_report" model="ir.actions.act_window">
        <field name="name">GA4 Reports</field>
        <field name="res_model">ga4.report</field>
        <field name="view_mode">list,graph,pivot,form</field>
        <field name="search_view_id" ref="view_ga4_report_search"/>
    </record>

    <record id="action_ga4_dashboard" model="ir.actions.client">
        <field name="name">GA4 Dashboard</field>
        <field name="tag">ga4_bigquery_dashboard</field>
    </record>
</odoo>
