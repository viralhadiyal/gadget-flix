<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ga4_raw_event_list" model="ir.ui.view">
        <field name="name">ga4.raw.event.list</field>
        <field name="model">ga4.raw.event</field>
        <field name="arch" type="xml">
            <list string="GA4 Raw Events">
                <field name="event_datetime"/>
                <field name="connection_id"/>
                <field name="event_name"/>
                <field name="user_pseudo_id"/>
                <field name="user_id" optional="hide"/>
                <field name="ga_session_id" optional="show"/>
                <field name="page_location"/>
                <field name="source"/>
                <field name="medium"/>
                <field name="campaign"/>
                <field name="device_category"/>
                <field name="country"/>
                <field name="city"/>
                <field name="transaction_id" optional="show"/>
                <field name="purchase_revenue" optional="show" sum="Revenue"/>
                <field name="engagement_time_msec" optional="hide" sum="Engagement Time"/>
            </list>
        </field>
    </record>

    <record id="view_ga4_raw_event_form" model="ir.ui.view">
        <field name="name">ga4.raw.event.form</field>
        <field name="model">ga4.raw.event</field>
        <field name="arch" type="xml">
            <form string="GA4 Raw Event">
                <sheet>
                    <group>
                        <group>
                            <field name="connection_id"/>
                            <field name="unique_key"/>
                            <field name="event_date"/>
                            <field name="event_datetime"/>
                            <field name="event_name"/>
                            <field name="user_pseudo_id"/>
                            <field name="user_id"/>
                            <field name="ga_session_id"/>
                            <field name="ga_session_number"/>
                        </group>
                        <group>
                            <field name="stream_id"/>
                            <field name="platform"/>
                            <field name="device_category"/>
                            <field name="operating_system"/>
                            <field name="browser"/>
                            <field name="language"/>
                        </group>
                    </group>
                    <group string="Page and Campaign">
                        <field name="page_location"/>
                        <field name="page_title"/>
                        <field name="page_referrer"/>
                        <field name="source"/>
                        <field name="medium"/>
                        <field name="campaign"/>
                        <field name="country"/>
                        <field name="city"/>
                    </group>
                    <group string="Ecommerce and Engagement">
                        <field name="transaction_id"/>
                        <field name="currency"/>
                        <field name="purchase_revenue"/>
                        <field name="value"/>
                        <field name="engagement_time_msec"/>
                    </group>
                    <group>
                        <field name="event_params_json"/>
                        <field name="user_properties_json"/>
                        <field name="ecommerce_json"/>
                        <field name="raw_payload_json"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_ga4_raw_event_search" model="ir.ui.view">
        <field name="name">ga4.raw.event.search</field>
        <field name="model">ga4.raw.event</field>
        <field name="arch" type="xml">
            <search string="GA4 Raw Events">
                <field name="connection_id"/>
                <field name="event_name"/>
                <field name="user_pseudo_id"/>
                <field name="user_id"/>
                <field name="ga_session_id"/>
                <field name="page_location"/>
                <field name="source"/>
                <field name="medium"/>
                <field name="campaign"/>
                <field name="country"/>
                <field name="city"/>
                <field name="transaction_id"/>
                <filter name="group_event_name" string="Event" context="{'group_by': 'event_name'}"/>
                <filter name="group_event_date" string="Date" context="{'group_by': 'event_date'}"/>
                <filter name="group_source" string="Source" context="{'group_by': 'source'}"/>
                <filter name="group_device" string="Device" context="{'group_by': 'device_category'}"/>
                <filter name="group_campaign" string="Campaign" context="{'group_by': 'campaign'}"/>
                <filter name="group_country" string="Country" context="{'group_by': 'country'}"/>
                <filter name="group_session" string="Session" context="{'group_by': 'ga_session_id'}"/>
            </search>
        </field>
    </record>

    <record id="view_ga4_raw_event_graph" model="ir.ui.view">
        <field name="name">ga4.raw.event.graph</field>
        <field name="model">ga4.raw.event</field>
        <field name="arch" type="xml">
            <graph string="GA4 Raw Events" type="bar">
                <field name="event_date" interval="day"/>
                <field name="id" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_ga4_raw_event_pivot" model="ir.ui.view">
        <field name="name">ga4.raw.event.pivot</field>
        <field name="model">ga4.raw.event</field>
        <field name="arch" type="xml">
            <pivot string="GA4 Raw Events">
                <field name="event_name" type="row"/>
                <field name="event_date" interval="month" type="col"/>
                <field name="id" type="measure"/>
                <field name="purchase_revenue" type="measure"/>
                <field name="engagement_time_msec" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_ga4_raw_event" model="ir.actions.act_window">
        <field name="name">GA4 Raw Events</field>
        <field name="res_model">ga4.raw.event</field>
        <field name="view_mode">list,graph,pivot,form</field>
        <field name="search_view_id" ref="view_ga4_raw_event_search"/>
    </record>
</odoo>
