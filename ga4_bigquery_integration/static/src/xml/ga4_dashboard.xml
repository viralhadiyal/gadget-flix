<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="ga4_bigquery_integration.Dashboard">
        <Layout display="display">
            <div class="o_ga4_dashboard">
                <div class="o_ga4_dashboard__topbar">
                    <div>
                        <h1>GA4 Analytics</h1>
                        <div class="o_ga4_dashboard__subtitle">
                            <t t-if="state.data.connection_name">
                                <t t-esc="state.data.connection_name"/> · Property <t t-esc="state.data.property_id"/> ·
                                <t t-esc="state.data.date_from"/> to <t t-esc="state.data.date_to"/>
                            </t>
                            <t t-else="">Configure a GA4 connection to start analysis.</t>
                        </div>
                    </div>
                    <div class="o_ga4_dashboard__filters">
                        <select class="form-select" t-on-change="setConnection" t-att-value="state.connectionId || ''">
                            <option value="">No Connection</option>
                            <t t-foreach="state.data.connections || []" t-as="connection" t-key="connection.id">
                                <option t-att-value="connection.id" t-att-selected="connection.id === state.connectionId">
                                    <t t-esc="connection.name"/>
                                </option>
                            </t>
                        </select>
                        <div class="btn-group">
                            <button class="btn btn-secondary" t-att-class="{'active': state.periodDays === 7}" t-on-click="() => this.setPeriod(7)">7D</button>
                            <button class="btn btn-secondary" t-att-class="{'active': state.periodDays === 30}" t-on-click="() => this.setPeriod(30)">30D</button>
                            <button class="btn btn-secondary" t-att-class="{'active': state.periodDays === 90}" t-on-click="() => this.setPeriod(90)">90D</button>
                        </div>
                        <button class="btn btn-primary" t-on-click="loadDashboard">Refresh</button>
                    </div>
                </div>

                <t t-if="state.loading">
                    <div class="o_ga4_dashboard__empty">Loading GA4 dashboard...</div>
                </t>
                <t t-elif="!state.data.connection_id">
                    <div class="o_ga4_dashboard__empty">
                        <h2>No GA4 connection configured</h2>
                        <button class="btn btn-primary" t-on-click="openConnections">Open Configuration</button>
                    </div>
                </t>
                <t t-else="">
                    <div class="o_ga4_dashboard__kpis">
                        <t t-foreach="state.data.kpis" t-as="kpi" t-key="kpi.label">
                            <div class="o_ga4_kpi">
                                <div class="o_ga4_kpi__label"><t t-esc="kpi.label"/></div>
                                <div class="o_ga4_kpi__value"><t t-esc="kpi.value"/></div>
                                <div class="o_ga4_kpi__change" t-att-class="'o_ga4_kpi__change--' + kpi.direction">
                                    <t t-esc="kpi.change"/>% vs previous period
                                </div>
                            </div>
                        </t>
                    </div>

                    <div class="o_ga4_dashboard__grid">
                        <section class="o_ga4_panel o_ga4_panel--wide">
                            <div class="o_ga4_panel__header">
                                <h2>Views Trend</h2>
                                <button class="btn btn-light" t-on-click="openReports">Open Reports</button>
                            </div>
                            <div class="o_ga4_trend">
                                <t t-foreach="state.data.trend" t-as="point" t-key="point.date">
                                    <div class="o_ga4_trend__item" t-att-title="point.date + ': ' + point.views">
                                        <div class="o_ga4_trend__bar" t-att-style="'height:' + point.height + '%'"/>
                                    </div>
                                </t>
                            </div>
                        </section>

                        <section class="o_ga4_panel">
                            <div class="o_ga4_panel__header"><h2>Traffic Sources</h2></div>
                            <t t-call="ga4_bigquery_integration.RankedRows">
                                <t t-set="rows" t-value="state.data.top_sources"/>
                            </t>
                        </section>

                        <section class="o_ga4_panel">
                            <div class="o_ga4_panel__header"><h2>Top Pages</h2></div>
                            <t t-call="ga4_bigquery_integration.RankedRows">
                                <t t-set="rows" t-value="state.data.top_pages"/>
                            </t>
                        </section>

                        <section class="o_ga4_panel">
                            <div class="o_ga4_panel__header"><h2>GA4 Events</h2></div>
                            <t t-call="ga4_bigquery_integration.RankedRows">
                                <t t-set="rows" t-value="state.data.top_events"/>
                            </t>
                        </section>

                        <section class="o_ga4_panel">
                            <div class="o_ga4_panel__header">
                                <h2>Raw BigQuery Events</h2>
                                <button class="btn btn-light" t-on-click="openRawEvents">Open Events</button>
                            </div>
                            <t t-call="ga4_bigquery_integration.RankedRows">
                                <t t-set="rows" t-value="state.data.raw_summary"/>
                            </t>
                        </section>

                        <section class="o_ga4_panel o_ga4_panel--wide">
                            <div class="o_ga4_panel__header">
                                <h2>Sync Health</h2>
                                <button class="btn btn-light" t-on-click="openSyncLogs">Open Logs</button>
                            </div>
                            <div class="o_ga4_logs">
                                <t t-foreach="state.data.latest_logs" t-as="log" t-key="log.name">
                                    <div class="o_ga4_log">
                                        <span class="o_ga4_log__status" t-att-class="'o_ga4_log__status--' + log.status"/>
                                        <div>
                                            <strong><t t-esc="log.sync_type"/></strong>
                                            <span><t t-esc="log.start_datetime"/></span>
                                        </div>
                                        <div><t t-esc="log.records_fetched"/> records</div>
                                    </div>
                                </t>
                            </div>
                        </section>
                    </div>
                </t>
            </div>
        </Layout>
    </t>

    <t t-name="ga4_bigquery_integration.RankedRows">
        <div class="o_ga4_ranked">
            <t t-if="!rows || !rows.length">
                <div class="o_ga4_ranked__empty">No data available</div>
            </t>
            <t t-foreach="rows || []" t-as="row" t-key="row.label">
                <div class="o_ga4_ranked__row">
                    <div class="o_ga4_ranked__meta">
                        <span t-att-title="row.label"><t t-esc="row.label"/></span>
                        <strong><t t-esc="row.display_value"/></strong>
                    </div>
                    <div class="o_ga4_ranked__track">
                        <div class="o_ga4_ranked__bar" t-att-style="'width:' + row.bar + '%'"/>
                    </div>
                </div>
            </t>
        </div>
    </t>
</templates>
