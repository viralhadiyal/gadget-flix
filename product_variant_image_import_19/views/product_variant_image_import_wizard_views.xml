<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_product_variant_image_import_wizard_form" model="ir.ui.view">
        <field name="name">product.variant.image.import.wizard.form</field>
        <field name="model">product.variant.image.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Products With Variant Images">
                <group>
                    <field name="file" filename="filename"/>
                    <field name="filename" invisible="1"/>
                    <field name="update_existing"/>
                    <field name="clear_existing_extra_images"/>
                </group>
                <div class="alert alert-info" role="alert">
                    Image paths in Excel must exist on the Odoo server, for example: /home/erp/images/test1_red.jpg
                </div>
                <footer>
                    <button name="action_import_products" string="Import" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_product_variant_image_import_wizard" model="ir.actions.act_window">
        <field name="name">Import Products With Variant Images</field>
        <field name="res_model">product.variant.image.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_product_variant_image_import_root"
              name="Variant Image Import"
              sequence="90"/>

    <menuitem id="menu_product_variant_image_import_wizard"
              name="Import Products"
              parent="menu_product_variant_image_import_root"
              action="action_product_variant_image_import_wizard"
              sequence="10"/>
</odoo>
