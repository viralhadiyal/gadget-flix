<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         GTM DataLayer Push Templates

         Odoo generates ONE event_id on the backend and passes it to:
           1. dataLayer.push()  → GTM → Meta Pixel (browser)
           2. Graph API payload → CAPI (server)
         Meta deduplicates using the matching event_id.

         Browser event IDs are stored in request.params because error handlers
         can render this layout before custom request attributes are set.
         ============================================================ -->

    <!-- ==================== PageView ==================== -->
    <!-- Fires on every page. event_id set by ir_http._pre_dispatch -->
    <template id="facebook_datalayer_pageview" inherit_id="website.layout">
        <xpath expr="//head" position="inside">
            <script type="text/javascript">
                <t t-set="fb_pv_event_id" t-value="request.fb_pv_event_id or ''"/>
                window.dataLayer = window.dataLayer || [];
                dataLayer.push({
                    event: 'meta_pageview',
                    event_id: '<t t-esc="fb_pv_event_id"/>' || ('pv_' + Date.now())
                });
            </script>
        </xpath>
    </template>

    <!-- ==================== ViewContent ==================== -->
    <!-- Product detail page — event_id set by shop_product controller -->
    <template id="facebook_datalayer_view_content" inherit_id="website_sale.product">
        <xpath expr="//section[@id='product_detail']" position="after">
            <t t-set="fb_vc_event_id" t-value="request.fb_vc_event_id or ''"/>
            <t t-if="fb_vc_event_id">
                <script type="text/javascript">
                    window.dataLayer = window.dataLayer || [];
                    dataLayer.push({
                        event: 'view_content',
                        product_id: '<t t-esc="product.id"/>',
                        content_name: '<t t-esc="product.name"/>',
                        value: <t t-esc="combination_info['price']"/>,
                        currency: '<t t-esc="website.currency_id.name"/>',
                        event_id: '<t t-esc="fb_vc_event_id"/>'
                    });
                </script>
            </t>
        </xpath>
    </template>

    <!-- ==================== AddToCart ==================== -->
    <!-- /shop/cart page — event_id set by cart controller -->
    <template id="facebook_datalayer_add_to_cart" inherit_id="website_sale.cart">
        <xpath expr="//div[@id='shop_cart']" position="before">
            <t t-set="fb_atc_event_id" t-value="request.fb_atc_event_id or ''"/>
            <t t-if="fb_atc_event_id">
                <script type="text/javascript">
                    window.dataLayer = window.dataLayer || [];
                    dataLayer.push({
                        event: 'add_to_cart',
                        value: <t t-esc="website_sale_order.amount_total"/>,
                        currency: '<t t-esc="website_sale_order.currency_id.name"/>',
                        event_id: '<t t-esc="fb_atc_event_id"/>'
                    });
                </script>
            </t>
        </xpath>
    </template>

    <!-- ==================== InitiateCheckout ==================== -->
    <!-- /shop/checkout — event_id set by shop_checkout controller -->
    <template id="facebook_datalayer_checkout" inherit_id="website_sale.checkout_layout">
        <xpath expr="//div[hasclass('oe_website_sale')]" position="after">
            <t t-set="fb_checkout_event_id" t-value="request.fb_checkout_event_id or ''"/>
            <t t-if="fb_checkout_event_id">
                <script type="text/javascript">
                    window.dataLayer = window.dataLayer || [];
                    if (window.location.pathname.indexOf('/shop/checkout') !== -1 ||
                        window.location.pathname.indexOf('/shop/address') !== -1) {
                        dataLayer.push({
                            event: 'initiate_checkout',
                            value: <t t-esc="website_sale_order.amount_total"/>,
                            currency: '<t t-esc="website_sale_order.currency_id.name"/>',
                            event_id: '<t t-esc="fb_checkout_event_id"/>'
                        });
                    }
                </script>
            </t>
        </xpath>
    </template>

    <!-- ==================== Purchase ==================== -->
    <!-- /shop/confirmation — deterministic event_id matches CAPI in sale_order.py -->
    <template id="facebook_datalayer_purchase" inherit_id="website_sale.confirmation">
        <xpath expr="//t[@t-call='website_sale.checkout_layout']" position="inside">
            <script type="text/javascript">
                if (!window._purchase_fired_) {
                    window._purchase_fired_ = true;

                    window.dataLayer = window.dataLayer || [];
                    dataLayer.push({
                        event: 'purchase',
                        value: <t t-esc="order.amount_total"/>,
                        currency: '<t t-esc="order.currency_id.name"/>',
                        order_id: '<t t-esc="order.id"/>',
                        event_id: 'order_<t t-esc="order.id"/>'
                    });
                }

            </script>
        </xpath>
    </template>

</odoo>
