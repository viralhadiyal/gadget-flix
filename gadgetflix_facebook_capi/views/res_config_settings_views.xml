<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.facebook.capi</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="website.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='google_analytics_setting']" position="after">
                <block title="Facebook Conversion API (CAPI)" id="facebook_capi_setting">
                    <setting string="Facebook Pixel ID" help="Your Meta Pixel ID">
                        <field name="facebook_pixel_id"/>
                    </setting>
                    <setting string="Conversion API Token" help="Generated from Meta Events Manager">
                        <field name="facebook_capi_token" password="True"/>
                    </setting>
                    <setting string="Test Event Code" help="Used for testing in Events Manager (e.g. TEST12345)">
                        <field name="facebook_capi_test_code"/>
                    </setting>
                    <setting string="API Version" help="Graph API version (e.g. v19.0)">
                        <field name="facebook_capi_api_version"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
