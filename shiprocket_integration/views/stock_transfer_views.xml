<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="sr_integration_stock_picking_form" model="ir.ui.view">
        <field name="name">stock.picking.form.shiprocket.integration</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock_delivery.view_picking_withcarrier_out_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='tracking']" position="after">
                <field name="country_code" invisible="1"/>
                <field name="sr_integration_eway_bill" invisible="country_code != 'IN'"/>
                <field name="sr_integration_order_refs" invisible="1"/>
            </xpath>
        </field>
    </record>

</odoo>
