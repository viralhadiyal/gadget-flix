<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="product_sr_integration_delivery" model="product.product">
            <field name="name">Shiprocket  Courier Service</field>
            <field name="default_code">SRI-DELIVERY</field>
            <field name="type">service</field>
            <field name="categ_id" ref="delivery.product_category_deliveries"/>
            <field name="sale_ok" eval="False"/>
            <field name="purchase_ok" eval="False"/>
            <field name="list_price">0.0</field>
            <field name="taxes_id" eval="[(5,)]"/>
        </record>

        <record id="sr_integration_box_0500" model="stock.package.type">
            <field name="name">Shiprocket Micro Box 0.5kg</field>
            <field name="shipper_package_code">SRI-MICRO</field>
            <field name="package_carrier_type">shiprocket_integration</field>
            <field name="height">5</field>
            <field name="width">5</field>
            <field name="packaging_length">5</field>
            <field name="max_weight">0.5</field>
        </record>

        <record id="sr_integration_box_1000" model="stock.package.type">
            <field name="name">Shiprocket Compact Box 1kg</field>
            <field name="shipper_package_code">SRI-COMPACT</field>
            <field name="package_carrier_type">shiprocket_integration</field>
            <field name="height">10</field>
            <field name="width">10</field>
            <field name="packaging_length">10</field>
            <field name="max_weight">1</field>
        </record>

        <record id="sr_integration_box_2000" model="stock.package.type">
            <field name="name">Shiprocket Standard Box 2kg</field>
            <field name="shipper_package_code">SRI-STANDARD</field>
            <field name="package_carrier_type">shiprocket_integration</field>
            <field name="height">20</field>
            <field name="width">20</field>
            <field name="packaging_length">20</field>
            <field name="max_weight">2</field>
        </record>

        <record id="delivery_method_sr_india_parcel" model="delivery.carrier">
            <field name="name">Shiprocket Courier</field>
            <field name="product_id" ref="shiprocket_integration.product_sr_integration_delivery"/>
            <field name="delivery_type">shiprocket_integration</field>
            <field name="country_ids" eval="[(6, 0, [ref('base.in')])]"/>
            <field name="sr_integration_package_type_id" ref="shiprocket_integration.sr_integration_box_0500"/>
        </record>

    </data>
</odoo>
